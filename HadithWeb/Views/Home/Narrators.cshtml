@model IEnumerable<string>
<div class="container mt-5 text-right" dir="rtl">
    <h2 class="text-primary mb-4 border-bottom pb-2">أشهر رواة الأحاديث</h2>
    <div class="row">
        <div class="row">
            @foreach (var name in Model)
            {
                <div class="col-md-4 mb-3">
                    <div class="card shadow-sm border-0 islamic-card">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <h5 class="m-0 font-cairo">@name</h5>
                    
                            <a asp-controller="Hadith" asp-action="Search" asp-route-searchTerm="@name" class="btn btn-outline-info rounded-pill">
                                عرض الأحاديث
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>