@{
    ViewData["Title"] = "الرئيسية - موقع الحديث النبوي";
}

<div class="container mt-5" dir="rtl">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">حديث ويب</h1>
        <p class="lead text-secondary">منصة متكاملة لتصفح السنة النبوية الشريفة</p>
    </div>

    <div class="row justify-content-center mb-5">
        <div class="col-md-10">
            <div class="card shadow-sm border-0 p-4" style="border-radius: 20px; background-color: #ffffff;">
                <form asp-controller="Hadith" asp-action="Search" method="get">
                    <div class="input-group input-group-lg shadow-sm mb-3">
                        <input type="text" name="searchTerm" class="form-control border-0 text-right" placeholder="ابحث عن نص حديث أو اسم راوي..." required>
                        <button class="btn btn-primary px-5" type="submit">
                            <i class="fas fa-search ml-2"></i> بحث
                        </button>
                    </div>
                    
                    <div class="text-center mt-3">
                        <div class="form-check form-check-inline mx-3">
                            <input class="form-check-input" type="radio" name="filter" id="f_hadith" value="hadith" checked>
                            <label class="form-check-label mr-2" for="f_hadith">البحث في نص الحديث</label>
                        </div>
                        <div class="form-check form-check-inline mx-3">
                            <input class="form-check-input" type="radio" name="filter" id="f_narrator" value="narrator">
                            <label class="form-check-label mr-2" for="f_narrator">البحث باسم الراوي</label>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-5 mb-3">
            <a asp-controller="Home" asp-action="Categories" class="btn btn-success btn-lg w-100 py-4 shadow-sm border-0" style="border-radius: 15px;">
                <i class="fas fa-layer-group fa-2x mb-2 d-block"></i>
                تصفح كافة التصنيفات
            </a>
        </div>
        <div class="col-md-5 mb-3">
            <a asp-controller="Home" asp-action="Narrators" class="btn btn-info btn-lg w-100 py-4 shadow-sm text-white border-0" style="border-radius: 15px;">
                <i class="fas fa-users fa-2x mb-2 d-block"></i>
                تصفح كافة الرواة
            </a>
        </div>
    </div>
</div>