@model IEnumerable<HadithWeb.Models.Hadith>

<div class="container mt-4" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="text-dark font-amiri">نتائج البحث عن: <span class="text-primary">"@ViewBag.SearchTerm"</span></h3>
        <span class="badge bg-secondary p-2">عدد النتائج: @(Model?.Count() ?? 0)</span>
    </div>

    <hr />

    @if (Model != null && Model.Any())
    {
        <div class="list-group">
            @foreach (var item in Model)
            {
                <div class="card mb-4 shadow-sm border-0 islamic-card">
                    <div class="card-body">
                        <h5 class="card-title text-dark mb-3" style="line-height: 2; font-family: 'Amiri', serif; font-size: 1.3rem;">
                            @item.Content
                        </h5>
                        <div class="d-flex justify-content-between align-items-center border-top pt-3 mt-3">
                            <div class="narrator-info">
                                <span class="text-muted">الراوي:</span>
                                <strong class="text-primary mx-1">@(item.Narrator?.Name ?? "غير معروف")</strong>
                            </div>
                            <span class="badge rounded-pill bg-light text-dark border p-2">المصدر: @item.Source</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-secondary text-center shadow-sm p-5 border-0" style="border-radius: 15px; background-color: rgba(255,255,255,0.7);">
            <i class="bi bi-search mb-3" style="font-size: 2rem;"></i>
            <h4>لم يتم العثور على أحاديث تطابق بحثك.</h4>
            <p class="text-muted">جرب البحث بكلمة أخرى أو باسم راوٍ آخر.</p>
            <a href="/" class="btn btn-outline-primary mt-3">العودة للرئيسية</a>
        </div>
    }
</div>