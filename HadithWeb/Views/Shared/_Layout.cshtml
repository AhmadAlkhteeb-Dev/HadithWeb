<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - حديث ويب</title>

    <link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Cairo:wght@300;400;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
            /* التنسيقات الجمالية للخلفية المتفاعلة */
            body {
                font-family: 'Cairo', sans-serif;
                background: radial-gradient(circle at center, #ffffff 0%, #f1eee4 100%) !important;
                background-attachment: fixed;
                position: relative;
                min-height: 100vh;
                overflow-x: hidden;
            }

                /* طبقة الزخرفة الإسلامية */
                body::before {
                    content: "";
                    position: fixed;
                    top: 0;
                    left: 0;
                    width: 100%;
                    height: 100%;
                    background-image: url('https://www.transparenttextures.com/patterns/islamic-art.png');
                    opacity: 0.08;
                    z-index: -1;
                    /* هامة جداً لكي لا تمنع النقر على الأزرار */
                    pointer-events: none;
                }

            .navbar {
                background: rgba(255, 255, 255, 0.9) !important;
                backdrop-filter: blur(10px);
                border-bottom: 1px solid rgba(0,0,0,0.05);
            }

            .font-amiri {
                font-family: 'Amiri', serif;
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light box-shadow mb-3 py-3 shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold text-primary fs-3" asp-area="" asp-controller="Home" asp-action="Index">HadithWeb</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold" asp-controller="Home" asp-action="Index">الرئيسية</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold" asp-controller="Home" asp-action="Narrators">الرواة</a>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center gap-2">
                        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary px-4 rounded-pill">تسجيل الدخول</a>
                        <a asp-controller="Account" asp-action="Register" class="btn btn-primary px-4 rounded-pill">إنشاء حساب</a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
            document.addEventListener('DOMContentLoaded', function() {
                // 1. تأثير تحريك الزخرفة مع حركة الماوس
                document.addEventListener('mousemove', (e) => {
                    const moveX = (e.clientX * 0.015);
                    const moveY = (e.clientY * 0.015);
                    document.body.style.backgroundPosition = `${moveX}px ${moveY}px`;
                });

                // 2. أنيميشن بسيط عند تحميل الصفحة
                const mainContent = document.querySelector('main');
                if (mainContent) {
                    mainContent.style.opacity = '0';
                    mainContent.style.transform = 'translateY(10px)';
                    mainContent.style.transition = 'all 0.8s ease-out';
                    setTimeout(() => {
                        mainContent.style.opacity = '1';
                        mainContent.style.transform = 'translateY(0)';
                    }, 100);
                }
            });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>